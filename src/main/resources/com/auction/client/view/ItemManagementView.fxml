<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ItemManagementController">

    <!-- Thanh Header (Chứa nút Đăng xuất) -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #388e3c; -fx-padding: 15;">
            <Label text="QUẢN LÝ SẢN PHẨM (SELLER)" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #388e3c; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- Phần thân chính -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <!-- Form nhập liệu -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Loại:"/>
                <ComboBox fx:id="cbType" prefWidth="120"/>

                <Label text="ID:"/>
                <TextField fx:id="txtId" prefWidth="100" promptText="Nhập ID"/>

                <Label text="Tên:"/>
                <TextField fx:id="txtName" prefWidth="150" promptText="Nhập Tên SP"/>

                <Label text="Giá:"/>
                <TextField fx:id="txtPrice" prefWidth="100" promptText="Nhập Giá"/>

                <!-- Nút gọi hàm handleAddItem -->
                <Button text="Thêm Sản Phẩm" onAction="#handleAddItem" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Bảng hiển thị dữ liệu -->
            <TableView fx:id="table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" text="Mã Sản Phẩm" prefWidth="150"/>
                    <TableColumn fx:id="nameCol" text="Tên Sản Phẩm" prefWidth="300"/>
                    <TableColumn fx:id="priceCol" text="Giá Khởi Điểm" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>