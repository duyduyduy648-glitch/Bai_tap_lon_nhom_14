<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminController">
    <!-- Thanh Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #d32f2f; -fx-padding: 15;">
            <Label text="TRANG QUẢN TRỊ VIÊN (ADMIN)" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #d32f2f; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- Phần thân giữa -->
    <center>
        <VBox alignment="CENTER" spacing="30">
            <Label text="Chào mừng Admin! Chọn chức năng để tiếp tục:" style="-fx-font-size: 16px;"/>
            <HBox alignment="CENTER" spacing="20">
                <Button text="Quản lý Người dùng" prefWidth="160" prefHeight="50" style="-fx-font-size: 14px;"/>
                <Button text="Quản lý Hệ thống" prefWidth="160" prefHeight="50" style="-fx-font-size: 14px;"/>
                <Button text="Thống kê doanh thu" prefWidth="160" prefHeight="50" style="-fx-font-size: 14px;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>